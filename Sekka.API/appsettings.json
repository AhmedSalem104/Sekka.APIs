{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=SekkaDb;User Id=sa;Password=YOUR_PASSWORD;TrustServerCertificate=true;"
  },

  "JwtSettings": {
    "SecretKey": "CHANGE_ME_IN_PRODUCTION_MIN_32_CHARS_LONG_!@#$",
    "Issuer": "Sekka.API",
    "Audience": "Sekka.Mobile",
    "AccessTokenExpiryMinutes": 1440,
    "RefreshTokenExpiryDays": 30
  },

  "OtpSettings": {
    "Length": 4,
    "ExpiryMinutes": 5,
    "MaxAttemptsPerNumber": 5,
    "MaxAttemptsWindowMinutes": 60,
    "ResendCooldownSeconds": 60,
    "MaxResendPerNumber": 3,
    "UseFakeOtpInDev": true,
    "FakeOtpCode": "1234"
  },

  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "Sekka_"
  },

  "FileStorage": {
    "BasePath": "wwwroot/uploads",
    "BaseUrl": "https://api.sekka.app/uploads",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ]
  },

  "AppSettings": {
    "MaxOrdersPerDay": 100,
    "CashAlertThresholdEGP": 2000,
    "StaleOrderMinutes": 30,
    "MaxDeliveryAttempts": 3,
    "DemoSessionExpiryHours": 24
  },

  "CorsPolicy": {
    "AllowedOrigins": [ "https://admin.sekka.app", "https://sekka.app" ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE" ],
    "AllowedHeaders": [ "Authorization", "Content-Type", "X-Idempotency-Key", "X-Api-Version" ]
  },

  "ApiVersioning": {
    "DefaultVersion": "1.0",
    "AssumeDefaultVersionWhenUnspecified": true,
    "ReportApiVersions": true
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
